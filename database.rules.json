{
  "rules": {
    "psychologists": {
      ".read": true,
      ".write": false
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "favorites": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "appointments": {
      ".read": true,
      ".indexOn": ["psychologistId"],
      "$appointmentId": {
        ".write": "auth != null && (!data.exists() ? newData.child('userId').val() === auth.uid : data.child('userId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['userId', 'psychologistId', 'date', 'time', 'name', 'email', 'phone', 'createdAt']) && newData.child('userId').val() === auth.uid"
      }
    }
  }
}
