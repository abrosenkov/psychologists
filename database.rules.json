{
  "rules": {
    "psychologists": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "favorites": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "appointments": {
      ".read": true,
      ".indexOn": ["psychologistId", "userId"],
      "$appointmentId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() ? newData.child('userId').val() === auth.uid : data.child('userId').val() === auth.uid))",
        ".validate": "newData.hasChildren(['userId', 'psychologistId', 'date', 'time', 'name', 'email', 'phone', 'createdAt']) && (root.child('users').child(auth.uid).child('role').val() === 'admin' || newData.child('userId').val() === auth.uid)"
      }
    },
    "availability": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
